{
  "name": "LPF Dashboard",
  "dataColors": [
    "#0cbad8",
    "#daa813",
    "#1a6e7e",
    "#f0c040",
    "#0e8fa6",
    "#b8860b",
    "#5bc8db",
    "#e8b820",
    "#085c6e",
    "#c49a0a"
  ],
  "good": "#2ecc71",
  "neutral": "#f39c12",
  "bad": "#e74c3c",
  "maximum": "#0cbad8",
  "center": "#daa813",
  "minimum": "#e74c3c",
  "null": "#d0d0d0",
  "background": "#FFFFFF",
  "foreground": "#1a1a2e",
  "tableAccent": "#0cbad8",
  "visualStyles": {
    "*": {
      "*": {
        "fontFamily": [{ "value": "Segoe UI" }],
        "fontSize": [{ "value": 11 }],
        "color": [{ "solid": { "color": "#1a1a2e" } }],
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }]
      }
    },
    "page": {
      "*": {
        "background": [{ "solid": { "color": "#f5f7fa" } }],
        "outspacePane": [{ "solid": { "color": "#f5f7fa" } }]
      }
    },
    "card": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "shadow": [{ "value": true }],
        "calloutValue": [{
          "fontSize": 28,
          "fontFamily": "Segoe UI Semibold",
          "color": { "solid": { "color": "#0cbad8" } }
        }],
        "categoryLabel": [{
          "fontSize": 11,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#6b7280" } }
        }]
      }
    },
    "multiRowCard": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "cardPadding": [{ "value": 12 }],
        "dataLabels": [{
          "fontSize": 13,
          "fontFamily": "Segoe UI Semibold",
          "color": { "solid": { "color": "#1a1a2e" } }
        }],
        "categoryLabels": [{
          "fontSize": 10,
          "color": { "solid": { "color": "#6b7280" } }
        }]
      }
    },
    "barChart": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "categoryAxis": [{
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } }
        }],
        "valueAxis": [{
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } },
          "gridlineThickness": 1
        }],
        "dataLabels": [{
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#1a1a2e" } }
        }],
        "legend": [{
          "fontSize": 10,
          "color": { "solid": { "color": "#6b7280" } }
        }]
      }
    },
    "columnChart": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "categoryAxis": [{
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } }
        }],
        "valueAxis": [{
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } },
          "gridlineThickness": 1
        }],
        "dataLabels": [{
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "color": { "solid": { "color": "#1a1a2e" } }
        }]
      }
    },
    "lineChart": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "categoryAxis": [{
          "fontSize": 10,
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } }
        }],
        "valueAxis": [{
          "fontSize": 10,
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } }
        }],
        "dataPoint": [{
          "defaultColor": { "solid": { "color": "#0cbad8" } },
          "strokeWidth": 2
        }]
      }
    },
    "tableEx": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "header": [{
          "fontSize": 11,
          "fontFamily": "Segoe UI Semibold",
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#0cbad8" } }
        }],
        "rows": [{
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "fontColor": { "solid": { "color": "#1a1a2e" } },
          "backColor": { "solid": { "color": "#FFFFFF" } },
          "altBackColor": { "solid": { "color": "#f5f7fa" } }
        }],
        "total": [{
          "fontSize": 11,
          "fontFamily": "Segoe UI Semibold",
          "fontColor": { "solid": { "color": "#1a1a2e" } },
          "backColor": { "solid": { "color": "#e8f7fb" } }
        }]
      }
    },
    "matrix": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "columnHeaders": [{
          "fontSize": 11,
          "fontFamily": "Segoe UI Semibold",
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#0cbad8" } }
        }],
        "rowHeaders": [{
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "fontColor": { "solid": { "color": "#1a1a2e" } },
          "backColor": { "solid": { "color": "#f5f7fa" } }
        }],
        "values": [{
          "fontSize": 10,
          "fontColor": { "solid": { "color": "#1a1a2e" } },
          "backColor": { "solid": { "color": "#FFFFFF" } },
          "altBackColor": { "solid": { "color": "#f5f7fa" } }
        }]
      }
    },
    "slicer": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "header": [{
          "fontSize": 11,
          "fontFamily": "Segoe UI Semibold",
          "fontColor": { "solid": { "color": "#1a1a2e" } },
          "backColor": { "solid": { "color": "#FFFFFF" } }
        }],
        "items": [{
          "fontSize": 10,
          "fontColor": { "solid": { "color": "#1a1a2e" } },
          "backColor": { "solid": { "color": "#FFFFFF" } }
        }],
        "selection": [{
          "selectAllCheckboxEnabled": true,
          "singleSelect": false
        }]
      }
    },
    "scatterChart": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "border": [{ "solid": { "color": "#e8e8e8" } }],
        "categoryAxis": [{
          "fontSize": 10,
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } }
        }],
        "valueAxis": [{
          "fontSize": 10,
          "color": { "solid": { "color": "#6b7280" } },
          "gridlineColor": { "solid": { "color": "#f0f0f0" } }
        }]
      }
    },
    "title": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "fontColor": [{ "solid": { "color": "#1a1a2e" } }],
        "fontSize": [{ "value": 13 }],
        "fontFamily": [{ "value": "Segoe UI Semibold" }],
        "borderColor": [{ "solid": { "color": "#0cbad8" } }],
        "borderWidth": [{ "value": 2 }]
      }
    },
    "textbox": {
      "*": {
        "background": [{ "solid": { "color": "#FFFFFF" } }],
        "fontColor": [{ "solid": { "color": "#1a1a2e" } }],
        "fontSize": [{ "value": 11 }],
        "fontFamily": [{ "value": "Segoe UI" }]
      }
    }
  },
  "textClasses": {
    "callout": {
      "fontSize": 45,
      "fontFace": "Segoe UI Semibold",
      "color": "#0cbad8"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#1a1a2e"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#1a1a2e"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#6b7280"
    }
  }
}
